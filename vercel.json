{
  "version": 2,
  "builds": [
    { "src": "api/*.py", "use": "@vercel/python" },
    { "src": "index.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/login",            "dest": "/api/automations.py" },
    { "src": "/api/automations",      "dest": "/api/automations.py" },
    { "src": "/api/automations/(.*)", "dest": "/api/automations.py" },
    { "src": "/api/lists",            "dest": "/api/automations.py" },
    { "src": "/api/campaigns",        "dest": "/api/automations.py" },
    { "src": "/webhook",              "dest": "/api/webhook.py" },
    { "src": "/",                     "dest": "/index.html" }
  ]
}
